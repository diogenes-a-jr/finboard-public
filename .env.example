# ═════════════════════════════════════════════════════════════════
# FinBoard One — variaveis de ambiente
# Copie este arquivo para `.env` e preencha. NUNCA commit o `.env`.
# ═════════════════════════════════════════════════════════════════

# ─── Servidor ─────────────────────────────────────────────────────
# Porta HTTP em que o servidor vai escutar (padrao 3000)
PORT=3000

# Host bind. Use 127.0.0.1 para acesso só local; 0.0.0.0 para acessar
# de outros devices na mesma rede WiFi (iPad via Safari, por exemplo).
HOST=127.0.0.1

# URL publica do deploy, sem barra final. Ex:
# APP_BASE_URL=https://finboard-public.onrender.com
APP_BASE_URL=

# Em producao, proteja o dashboard com login HTTP Basic.
# Fallback se GOOGLE_CLIENT_ID nao for configurado.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
FINBOARD_REQUIRE_LOGIN=false

# Login com Google Identity Services. Em producao, use este modo.
# GOOGLE_ALLOWED_EMAILS aceita lista separada por virgula; vazio permite
# qualquer conta Google valida para este client_id.
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_EMAILS=

# Em Vercel, use /tmp porque o filesystem da function nao e persistente.
# Para persistencia real de customizacoes, migre este KV para Postgres/KV.
DB_PATH=
SETTINGS_PATH=

# ─── Pluggy ───────────────────────────────────────────────────────
# Base URL da API (raramente muda)
PLUGGY_BASE_URL=https://api.pluggy.ai

# Credenciais Pluggy. Crie sua conta gratuita em https://dashboard.pluggy.ai
# e copie Client ID + Client Secret do dashboard.
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_ITEM_IDS=

# URL publica chamada pela Pluggy quando itens forem criados/atualizados.
# Em deploy, use: https://seu-dominio.com/api/webhooks/pluggy
PLUGGY_WEBHOOK_URL=

# ─── Auth do app ──────────────────────────────────────────────────
# Token aleatorio que protege as rotas /api/*. Gere com:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# e cole o valor abaixo. Se mudar, todas as sessoes abertas no browser
# precisam recarregar (o servidor seta como cookie no GET /).
APP_TOKEN=
